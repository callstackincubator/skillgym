---
import { Code } from 'astro:components';
import { SEO } from 'astro-seo';
import Logo from '../components/Logo.astro';
import { darkTheme } from '../lib/shiki.ts';

const pageTitle = 'skillgym — Test and benchmark agent skills';
const pageDescription =
  'Catch skill regressions, compare agents, and keep proof from every run. Use TypeScript assertions and token snapshots to verify SKILL.md behavior.';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const basePath = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const ogImageURL = new URL(`${basePath}og.jpg`, Astro.site);

const GITHUB = 'https://github.com/callstackincubator/skillgym';
const DOCS = 'https://github.com/callstackincubator/skillgym#readme';
const NPM = 'https://www.npmjs.com/package/skillgym';

const marqueeItems = [
  'Catch skill regressions','TypeScript assertions','Token usage snapshots',
  'Count tokens per run','Same skill, every agent','Proof from every run',
  'Inspect commands and file reads','OpenCode','Codex','Claude Code',
  'Real agent sessions','Isolated workspaces','Open source',
];
const doubled = [...marqueeItems, ...marqueeItems];

const assertCode = `\
import { assert } from "skillgym";

// assert the skill was loaded
assert.skills.has(report, "agent-device");

// assert the reference was loaded
assert.fileReads.includes(report, /bootstrap-install\\.md$/);

// assert commands ran in the right order
assert.commands.before(
  report,
  /^agent-device\s+open\b/,
  /^agent-device\s+snapshot\b/
);
assert.commands.before(
  report,
  /^agent-device\s+snapshot\b/,
  /^agent-device\s+close\b/
);`;

const workspaceCode = `\
export const workspace = {
  mode: "isolated",
  templateDir: "./fixtures/base",
  bootstrap: {
    command: "npm",
    args: ["install"],
  },
};`;

const configCode = `\
// skillgym.config.ts
import type { SkillGymConfig } from "skillgym";

const config: SkillGymConfig = {
  runners: {
    "my-agent": {
      agent: {
        type: "opencode",
        model: "openai/gpt-4o",
      },
    },
  },
};

export default config;`;

const suiteCode = `\
// skillgym/my-suite.ts
import { assert, type TestCase } from "skillgym";

const suite: TestCase[] = [
  {
    id: "agent-device-settings-check",
    prompt: [
      "Use agent-device to open Settings,",
      'verify "Privacy" is visible with snapshot,',
      "then close the session.",
    ].join(" "),
    async assert(report) {
      assert.skills.has(report, "agent-device");
      assert.commands.before(
        report,
        /^agent-device\s+open\b/,
        /^agent-device\s+snapshot\b/
      );
      assert.commands.before(
        report,
        /^agent-device\s+snapshot\b/,
        /^agent-device\s+close\b/
      );
    },
  },
];

export default suite;`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${basePath}favicon.svg`} />
    <link rel="icon" href={`${basePath}favicon.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO
      title={pageTitle}
      description={pageDescription}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          title: pageTitle,
          type: 'website',
          image: ogImageURL.toString(),
          url: canonicalURL,
        },
        optional: {
          description: pageDescription,
          siteName: 'skillgym',
        },
        image: {
          alt: 'skillgym — test and benchmark coding agents',
          type: 'image/jpeg',
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: pageTitle,
        description: pageDescription,
        image: ogImageURL.toString(),
        imageAlt: 'skillgym — test and benchmark coding agents',
      }}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link href="https://fonts.bunny.net/css?family=switzer:400,500&display=swap" rel="stylesheet" />
  </head>

  <body>

    <nav class="nav">
      <div class="nav-inner">
        <a href={basePath} class="nav-logo" aria-label="skillgym home">
          <Logo clipId="logo-nav" class="site-logo site-logo--nav" />
          <span class="logo-by">by Callstack</span>
        </a>
        <div class="nav-right">
          <a href={GITHUB} class="nav-gh" target="_blank" rel="noopener noreferrer">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.09.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.647.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.268 2.75 1.026A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.114 2.504.337 1.909-1.294 2.747-1.026 2.747-1.026.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
            GitHub
          </a>
          <a href={GITHUB} class="btn-primary" target="_blank" rel="noopener noreferrer">Get started</a>
        </div>
      </div>
    </nav>

    <section class="hero">
      <div class="grain"></div>
      <div class="hero-glow"></div>
      <div class="container hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">OPEN SOURCE · SKILL REGRESSION TESTING</p>
          <h1 class="hero-h1">Did your skill<br />still do the right thing?</h1>
          <p class="hero-lead">Catch skill regressions.<br />Keep the proof.</p>
          <div class="hero-actions">
            <a href={GITHUB} class="btn-primary btn-large" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.09.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.647.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.268 2.75 1.026A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.114 2.504.337 1.909-1.294 2.747-1.026 2.747-1.026.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
              </svg>
              Star on GitHub
            </a>
            <a href={DOCS} class="btn-ghost btn-large" target="_blank" rel="noopener noreferrer">Read the docs →</a>
          </div>
        </div>

        <div class="hero-visual">
          <div class="terminal">
            <div class="terminal-bar">
              <span class="t-dot" style="background:#FF5F56"></span>
              <span class="t-dot" style="background:#FFBD2E"></span>
              <span class="t-dot" style="background:#27C93F"></span>
              <span class="t-title">skillgym run</span>
            </div>
            <div class="terminal-body">
              <div class="terminal-content">
                <div class="tl"><span class="t-prompt">$</span> <span class="t-cmd">skillgym run ./examples/basic-suite.ts</span></div>
                <div class="tl tl-blank"></div>
                <div class="tl"><span class="t-k">Suite</span>      <span class="t-v">examples/basic-suite.ts</span></div>
                <div class="tl"><span class="t-k">Workspace</span>  <span class="t-v">~/Projects/acme-app</span></div>
                <div class="tl"><span class="t-k">Cases</span>      <span class="t-v">3</span></div>
                <div class="tl"><span class="t-k">Runners</span>    <span class="t-v">2</span></div>
                <div class="tl"><span class="t-k">Runs</span>       <span class="t-v">6</span></div>
                <div class="tl tl-blank"></div>
                <div class="tl tl-head-summary"><span></span><span>case</span><span>runs</span><span>status</span></div>
                <div class="tl tl-row-summary"><span class="t-pass">✓</span><span class="t-case">always-passes</span><span class="t-meta">2/2</span><span class="t-pass">passed</span></div>
                <div class="tl tl-row-summary"><span class="t-fail">✗</span><span class="t-case">assertion-fails</span><span class="t-meta">1/2</span><span class="t-fail">failed</span></div>
                <div class="tl tl-row-summary"><span class="t-fail">✗</span><span class="t-case">assert-crashes</span><span class="t-meta">0/2</span><span class="t-fail">failed</span></div>
                <div class="tl tl-blank"></div>
                <div class="tl tl-dim">Runner: open-main (opencode, openai/gpt-4o)</div>
                <div class="tl tl-head-runner"><span></span><span>case</span><span>time</span><span>in</span><span>out</span><span>billable</span></div>
                <div class="tl tl-row-runner"><span class="t-pass">✓</span><span class="t-case">always-passes</span><span class="t-meta">12.3s</span><span class="t-meta">1,240</span><span class="t-meta">890</span><span class="t-meta">8,204</span></div>
                <div class="tl tl-row-runner"><span class="t-pass">✓</span><span class="t-case">assertion-fails</span><span class="t-meta">14.8s</span><span class="t-meta">2,040</span><span class="t-meta">1,100</span><span class="t-meta">11,240</span></div>
                <div class="tl tl-row-runner"><span class="t-fail">✗</span><span class="t-case">assert-crashes</span><span class="t-meta">3.1s</span><span class="t-meta">410</span><span class="t-meta">120</span><span class="t-meta">892</span></div>
                <div class="tl tl-blank"></div>
                <div class="tl tl-summary"><span class="t-fail">2 failed</span> · <span class="t-pass">1 passed</span> · <span class="t-meta">1m 42s</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="marquee-wrap">
      <div class="marquee-fade">
        <div class="marquee-track">
          {doubled.map(item => (
            <span class="marquee-item">{item}</span>
          ))}
        </div>
      </div>
    </div>

    <section class="section-light">
      <div class="container">
        <div class="section-hdr">
          <p class="eyebrow eyebrow-light">HOW IT WORKS</p>
          <h2 class="h2-light">Change the skill. Check the run.</h2>
        </div>
        <div class="three-cards">
          <div class="card-light">
            <p class="card-label">RUN</p>
            <h3 class="card-title">Test the skill for real.</h3>
            <p class="card-body">Run real agent sessions after every <code>SKILL.md</code> change. Check what the agent actually did, not what you hoped it did.</p>
          </div>
          <div class="card-light card-light--mid">
            <p class="card-label">ASSERT</p>
            <h3 class="card-title">Assert the skill and the steps.</h3>
            <p class="card-body">Use TypeScript assertions to check the right skill was loaded, the right files were read, the right commands ran, and the answer held up.</p>
          </div>
          <div class="card-light">
            <p class="card-label">INSPECT</p>
            <h3 class="card-title">Every skill run leaves proof.</h3>
            <p class="card-body">When a skill edit changes behavior, compare artifacts, inspect the trail, and see how token usage moved.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section-light section-border-top">
      <div class="container">
        <div class="split">
          <div class="split-copy">
            <p class="eyebrow eyebrow-light">RUNNER</p>
            <h2 class="h2-light">Turn skill edits<br />into checks.</h2>
            <p class="split-body">When you change a <code>SKILL.md</code>, rerun the same cases and see what moved. skillgym records each run so failed skill behavior is easy to inspect.</p>
            <code class="inline-cmd">npm install --save-dev skillgym</code>
            <code class="inline-cmd" style="margin-top:8px">npx skillgym run ./skillgym/my-suite.ts</code>
          </div>
          <div class="split-visual">
            <div class="terminal terminal--sm">
              <div class="terminal-bar">
                <span class="t-dot" style="background:#FF5F56"></span>
                <span class="t-dot" style="background:#FFBD2E"></span>
                <span class="t-dot" style="background:#27C93F"></span>
                <span class="t-title">standard reporter</span>
              </div>
              <div class="terminal-body terminal-body--sm">
                <div class="terminal-content">
                  <div class="tl"><span class="t-k">Suite</span>      <span class="t-v">examples/basic-suite.ts</span></div>
                  <div class="tl"><span class="t-k">Workspace</span>  <span class="t-v">~/Projects/acme-app</span></div>
                  <div class="tl"><span class="t-k">Cases</span>      <span class="t-v">3</span></div>
                  <div class="tl"><span class="t-k">Runners</span>    <span class="t-v">2</span></div>
                  <div class="tl"><span class="t-k">Runs</span>       <span class="t-v">6</span></div>
                  <div class="tl tl-blank"></div>
                  <div class="tl tl-head-summary"><span></span><span>case</span><span>runs</span><span>status</span></div>
                  <div class="tl tl-row-summary"><span class="t-pass">✓</span><span class="t-case">always-passes</span><span class="t-meta">2/2</span><span class="t-pass">passed</span></div>
                  <div class="tl tl-row-summary"><span class="t-fail">✗</span><span class="t-case">assertion-fails</span><span class="t-meta">1/2</span><span class="t-fail">failed</span></div>
                  <div class="tl tl-row-summary"><span class="t-fail">✗</span><span class="t-case">assert-crashes</span><span class="t-meta">0/2</span><span class="t-fail">failed</span></div>
                  <div class="tl tl-blank"></div>
                  <div class="tl tl-dim">Runner: open-main (opencode, openai/gpt-4o)</div>
                  <div class="tl tl-head-runner"><span></span><span>case</span><span>time</span><span>in</span><span>out</span><span>billable</span></div>
                  <div class="tl tl-row-runner"><span class="t-pass">✓</span><span class="t-case">always-passes</span><span class="t-meta">12.3s</span><span class="t-meta">1,240</span><span class="t-meta">890</span><span class="t-meta">8,204</span></div>
                  <div class="tl tl-row-runner"><span class="t-pass">✓</span><span class="t-case">assertion-fails</span><span class="t-meta">14.8s</span><span class="t-meta">2,040</span><span class="t-meta">1,100</span><span class="t-meta">11,240</span></div>
                  <div class="tl tl-row-runner"><span class="t-fail">✗</span><span class="t-case">assert-crashes</span><span class="t-meta">3.1s</span><span class="t-meta">410</span><span class="t-meta">120</span><span class="t-meta">892</span></div>
                  <div class="tl tl-blank"></div>
                  <div class="tl tl-summary"><span class="t-fail">2 failed</span> · <span class="t-pass">1 passed</span> · <span class="t-meta">Duration 1m 42s</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-light section-border-top">
      <div class="container">
        <div class="split">
          <div class="split-copy">
            <p class="eyebrow eyebrow-light">RUNNERS</p>
            <h2 class="h2-light">Same skill.<br />Different agents.</h2>
            <p class="split-body">One skill edit can land differently on every runner. Compare OpenCode, Codex, and Claude Code on the same cases before you trust the change.</p>
          </div>
          <div class="split-visual">
            <div class="agent-stack">
              <div class="agent-card">
                <div class="agent-info">
                  <p class="agent-name">OpenCode</p>
                  <p class="agent-desc">an open source AI coding agent</p>
                </div>
                <span class="agent-badge">opencode</span>
              </div>
              <div class="agent-card">
                <div class="agent-info">
                  <p class="agent-name">Codex</p>
                  <p class="agent-desc">OpenAI's terminal coding agent</p>
                </div>
                <span class="agent-badge">codex</span>
              </div>
              <div class="agent-card">
                <div class="agent-info">
                  <p class="agent-name">Claude Code</p>
                  <p class="agent-desc">Anthropic's coding agent CLI</p>
                </div>
                <span class="agent-badge">claude-code</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-light section-border-top">
      <div class="container">
        <div class="split split--rev">
          <div class="split-visual">
            <div class="code-block">
              <div class="code-bar">
                <div class="code-dots">
                  <span class="c-dot"></span>
                  <span class="c-dot"></span>
                  <span class="c-dot"></span>
                </div>
                <span class="code-lang">assertions.ts</span>
              </div>
              <div class="code-inner">
                <Code code={assertCode} lang="typescript" theme={darkTheme} />
              </div>
            </div>
          </div>
          <div class="split-copy">
            <p class="eyebrow eyebrow-light">ASSERTIONS</p>
            <h2 class="h2-light">Good skill behavior<br />is testable.</h2>
            <p class="split-body">The right skill. The right files. The right steps. Use assertions to turn your expectations into pass or fail after every <code>SKILL.md</code> edit.</p>
            <ul class="assert-list">
               <li><code>assert.skills.*</code> — check which skills were used</li>
               <li><code>assert.commands.*</code> — check commands and ordering</li>
               <li><code>assert.fileReads.*</code> — check what the agent opened</li>
               <li><code>assert.toolCalls.*</code> — inspect tool usage in detail</li>
               <li><code>assert.output.*</code> — check the final answer</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="section-light section-border-top">
      <div class="container">
        <div class="bento-grid">
          <div class="bento-tile">
            <p class="bento-label">SNAPSHOTS</p>
            <h3 class="bento-title">Count tokens.<br />Catch costly skill regressions.</h3>
            <p class="bento-body">Set a baseline and catch when a skill edit makes the agent much more expensive. Track token growth before it becomes normal.</p>
            <pre class="bento-code">npx skillgym run ./suite.ts --update-snapshots</pre>
          </div>
          <div class="bento-tile bento-tile--dark">
            <p class="bento-label bento-label--dim">WORKSPACES</p>
            <h3 class="bento-title bento-title--light">Fresh workspace.<br />Honest skill runs.</h3>
            <p class="bento-body bento-body--dim">Use isolated workspaces when repo state matters, or share one when you want speed. Keep skill failures easier to reproduce and debug.</p>
            <div class="bento-code-wrap">
              <Code code={workspaceCode} lang="typescript" theme={darkTheme} />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-dark">
      <div class="container">
        <div class="section-hdr">
          <p class="eyebrow eyebrow-dark">QUICK START</p>
          <h2 class="h2-dark">From prompt to benchmark<br />in three steps.</h2>
        </div>
        <div class="steps-grid">
          <div class="step">
            <p class="step-num">01</p>
            <h3 class="step-title">Install</h3>
            <pre class="step-code step-code--plain">npm install --save-dev skillgym</pre>
          </div>
          <div class="step step--mid">
            <p class="step-num">02</p>
            <h3 class="step-title">Configure</h3>
            <div class="step-code-wrap">
              <Code code={configCode} lang="typescript" theme={darkTheme} />
            </div>
          </div>
          <div class="step">
            <p class="step-num">03</p>
            <h3 class="step-title">Run</h3>
            <div class="step-code-wrap">
              <Code code={suiteCode} lang="typescript" theme={darkTheme} />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="grain"></div>
      <div class="cta-glow"></div>
      <div class="container cta-inner">
        <p class="eyebrow eyebrow-dark">OPEN SOURCE · MIT LICENSE</p>
        <h2 class="cta-h2">Stop guessing.<br />Check the skill.</h2>
        <p class="cta-sub">Catch skill regressions, compare agents, and keep proof from every run.</p>
        <div class="cta-actions">
          <a href={GITHUB} class="btn-primary btn-large" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.09.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.647.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.268 2.75 1.026A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.114 2.504.337 1.909-1.294 2.747-1.026 2.747-1.026.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
            Star on GitHub
          </a>
          <a href={DOCS} class="cta-docs-link" target="_blank" rel="noopener noreferrer">Read the docs →</a>
        </div>
      </div>
    </section>

    <footer class="footer">
